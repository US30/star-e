# StAR-E Environment Configuration
# Copy this file to .env and update with your settings

# ==============================================================================
# Data Settings
# ==============================================================================

# Directory for storing data
STAR_E_DATA_DIR=./data

# MLflow tracking URI
STAR_E_MLFLOW_TRACKING_URI=mlruns

# ==============================================================================
# Binance API (Optional - Only for Cryptocurrency Features)
# ==============================================================================

# Get your API keys from: https://www.binance.com/en/my/settings/api-management
STAR_E_BINANCE_API_KEY=your_api_key_here
STAR_E_BINANCE_API_SECRET=your_api_secret_here

# Use testnet for development (true/false)
STAR_E_BINANCE_TESTNET=true

# ==============================================================================
# Model Configuration
# ==============================================================================

# Hidden Markov Model settings
STAR_E_HMM_N_STATES=3
STAR_E_HMM_COVARIANCE_TYPE=full

# Gaussian Mixture Model settings
STAR_E_GMM_N_COMPONENTS=3
STAR_E_GMM_COVARIANCE_TYPE=full

# LSTM settings
STAR_E_LSTM_HIDDEN_SIZE=64
STAR_E_LSTM_NUM_LAYERS=2
STAR_E_LSTM_SEQUENCE_LENGTH=21

# Temporal Fusion Transformer settings
STAR_E_TFT_HIDDEN_SIZE=64
STAR_E_TFT_ATTENTION_HEAD_SIZE=4
STAR_E_TFT_MAX_ENCODER_LENGTH=60
STAR_E_TFT_MAX_PREDICTION_LENGTH=21

# Graph Attention Network settings
STAR_E_GAT_HIDDEN_DIM=64
STAR_E_GAT_EMBEDDING_DIM=32
STAR_E_GAT_NUM_HEADS=4

# GARCH settings
STAR_E_GARCH_P=1
STAR_E_GARCH_Q=1

# Kalman Filter settings
STAR_E_KALMAN_PROCESS_NOISE=0.01
STAR_E_KALMAN_OBSERVATION_NOISE=0.1

# ==============================================================================
# Portfolio Settings
# ==============================================================================

# Minimum weight per asset
STAR_E_MIN_WEIGHT=0.0

# Maximum weight per asset
STAR_E_MAX_WEIGHT=0.3

# ==============================================================================
# Risk Management
# ==============================================================================

# VaR confidence level (0.95 = 95%)
STAR_E_VAR_CONFIDENCE=0.95

# CVaR confidence level
STAR_E_CVAR_CONFIDENCE=0.95

# Number of Monte Carlo simulations
STAR_E_MONTE_CARLO_SIMULATIONS=10000

# Risk-free rate (annual)
STAR_E_RISK_FREE_RATE=0.04

# ==============================================================================
# API & Dashboard Settings
# ==============================================================================

# API host and port
STAR_E_API_HOST=0.0.0.0
STAR_E_API_PORT=8000

# Streamlit dashboard port
STAR_E_DASHBOARD_PORT=8501

# React frontend URL (for CORS)
REACT_APP_API_URL=http://localhost:8000

# ==============================================================================
# Default Tickers
# ==============================================================================

# Comma-separated list of default stock tickers
STAR_E_DEFAULT_TICKERS=AAPL,MSFT,GOOGL,AMZN,META,NVDA,TSLA,JPM,V,JNJ

# Default cryptocurrency pairs
STAR_E_DEFAULT_CRYPTO_PAIRS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT

# Default start date for data fetching (YYYY-MM-DD)
STAR_E_DEFAULT_START_DATE=2018-01-01
